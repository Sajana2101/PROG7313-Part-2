<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF3E0">

    <!-- top header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:gravity="center"
        android:background="#43A047">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Expense"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- main form section -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- category dropdown -->
            <Spinner
                android:id="@+id/spnEditCategory"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="10dp"
                android:background="#FFFFFF"
                android:padding="12dp" />

            <!-- expense amount input -->
            <EditText
                android:id="@+id/edtEditAmount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="10dp"
                android:background="#FFFFFF"
                android:hint="Enter amount"
                android:inputType="numberDecimal"
                android:padding="12dp" />

            <!-- date picker field -->
            <EditText
                android:id="@+id/edtEditDate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="10dp"
                android:background="#FFFFFF"
                android:hint="Enter date"
                android:focusable="false"
                android:inputType="date"
                android:padding="12dp" />

            <!-- start time input -->
            <EditText
                android:id="@+id/edtEditStartTime"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="10dp"
                android:background="#FFFFFF"
                android:hint="Start time"
                android:focusable="false"
                android:inputType="time"
                android:padding="12dp" />

            <!-- end time input -->
            <EditText
                android:id="@+id/edtEditEndTime"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="10dp"
                android:background="#FFFFFF"
                android:hint="End time"
                android:focusable="false"
                android:inputType="time"
                android:padding="12dp" />

            <!-- description input -->
            <EditText
                android:id="@+id/edtEditDescription"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="16dp"
                android:background="#FFFFFF"
                android:gravity="top"
                android:hint="Enter description"
                android:inputType="textMultiLine"
                android:padding="12dp" />

            <!-- updates expense -->
            <Button
                android:id="@+id/btnUpdateExpense"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Update Expense"
                android:textAllCaps="false"
                android:layout_marginBottom="12dp" />

            <!-- cancels edit -->
            <Button
                android:id="@+id/btnCancelEdit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Cancel"
                android:textAllCaps="false" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>