<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF3E0"
    android:padding="22dp"
    android:id="@+id/main">

    <TextView
        android:id="@+id/tvRegHeading"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/register_page1"
        android:textAlignment="center"
        android:textColor="#1E3A8A"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvRegSub"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/create_your_budgetquest_account"
        android:textAlignment="center"
        android:textColor="#546E7A"
        android:textSize="15sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvRegHeading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/registerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/login_card_bg"
        android:padding="22dp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/tvRegSub"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/name_regHeading"
            android:textColor="#3F51B5"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etRegName"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/input_bg"
            android:hint="@string/register_please_enter_your_name"
            android:inputType="text"
            android:padding="18dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/password_regHeading"
            android:textColor="#D81B60"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etRegPassword"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/input_bg"
            android:hint="@string/register_please_enter_your_password"
            android:inputType="textPassword"
            android:padding="18dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/confirm_password"
            android:textColor="#D81B60"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etRegConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="26dp"
            android:background="@drawable/input_bg"
            android:hint="@string/please_confirm_your_password"
            android:inputType="textPassword"
            android:padding="18dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRegRegister"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/orangebtn_round"
            android:text="@string/register"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnRegSignIn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/loginbtn_outline"
            android:text="@string/already_have_an_account"
            android:textAllCaps="false"
            android:textColor="#3155D4" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>